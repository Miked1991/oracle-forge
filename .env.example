# Database routing uses OpenRouter only (agent/llm_reasoner.py). No Groq fallback.
# Optional: GROQ_API_KEY may still be used by other tooling outside routing.

# Model on OpenRouter for routing (and for ORACLE_FORGE_LLM_SQL generation if enabled).
MODEL_NAME=openai/gpt-4o-mini

# OpenRouter — required for routing unless tests mock OpenRouterRoutingReasoner.plan
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://your-site.example
OPENROUTER_APP_NAME=OracleForge

# MCP Toolbox endpoint used by agent/tools_client.py
MCP_BASE_URL=http://localhost:5000

# DB connection variables consumed by mcp/tools.yaml
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/oracleforge
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=yelp_db
SQLITE_PATH=D:/FDE-Training/oracle-forge/DataAgentBench/query_bookreview/query_dataset/review_query.db
DUCKDB_PATH=D:/FDE-Training/oracle-forge/DataAgentBench/query_yelp/query_dataset/yelp_user.db
# If MCP does not expose DuckDB, agent falls back to local DuckDB execution using this path.

# Schema registry (`python -m scripts.build_schema_registry`): use host-mapped Docker ports (e.g. localhost:5432, localhost:27017).
# If POSTGRES_DSN / MONGODB_URI are blank in the process environment, the builder fills them from `.env` (dotenv_values merge).
# Optional: docker-compose-style split vars instead of POSTGRES_DSN / MONGODB_URI
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=oracleforge
# MONGO_HOST=localhost
# MONGO_PORT=27017
# Optional overrides used only by the registry builder
# ORACLE_FORGE_REGISTRY_POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/oracleforge
# ORACLE_FORGE_REGISTRY_MONGODB_URI=mongodb://localhost:27017/
# ORACLE_FORGE_REGISTRY_MONGO_TIMEOUT_MS=30000

# Optional per-dataset overrides when run_agent(..., dataset_id="agnews") or eval passes dataset (Phase C).
# ORACLE_FORGE_DATASETS_CONFIG=D:/path/to/custom/datasets.json
# ORACLE_FORGE_DATASET_AGNEWS_SQLITE_PATH=D:/.../agnews_mongo.db
# ORACLE_FORGE_DATASET_AGNEWS_MONGODB_DATABASE=articles_db
# ORACLE_FORGE_DATASET_AGNEWS_DUCKDB_PATH=D:/.../agnews_user.db

# Log OpenRouter routing API failures to the Python logger (debugging).
# ORACLE_FORGE_DEBUG_LLM_ROUTING=false

# Optional: scripts/seed_yelp_postgres.py — default loads business rows from BSON on disk; set to load from MongoDB instead.
# YELP_SEED_USE_MONGO=false
# YELP_BUSINESS_BSON=

# Use mock mode only when explicitly desired for dry-runs.
# For real DAB evals this should stay false.
ORACLE_FORGE_MOCK_MODE=false

# When false, MCP outages fail fast (recommended for benchmark integrity).
# Set true only if you intentionally want auto-fallback to mock.
ORACLE_FORGE_ALLOW_MOCK_FALLBACK=false

# When true, LLM generates SQL / Mongo pipelines from KB + schema (no Yelp exact-string SQL oracle).
# When false (default), legacy heuristics + dab_yelp_postgres.py templates apply.
ORACLE_FORGE_LLM_SQL=false

# Optional: extra LLM call for phase 1 (planner) — intent JSON → AnswerContract instead of heuristic only.
# Inspect plan["query_pipeline"] and docs/driver_notes/sql_builder_llm_prompts.jsonl (pipeline_phase planner).
# ORACLE_FORGE_LLM_PLANNER=false

# If true, generated SQL must only reference tables/collections present in MCP schema metadata.
ORACLE_FORGE_SQL_STRICT_ALLOWLIST=true

# Live PRAGMA/information_schema/Mongo sample: populate per-table fields in schema_metadata after routing (recommended).
ORACLE_FORGE_ENRICH_SCHEMA_COLUMNS=true
# Log failed per-table enrich attempts (e.g. wrong POSTGRES_DSN) to the Python logger.
# ORACLE_FORGE_DEBUG_SCHEMA_ENRICH=false

# If true (requires sqlglot), reject SQL whose column identifiers are not in schema_metadata fields for that table.
ORACLE_FORGE_STRICT_SQL_COLUMNS=true

# Eval defaults (used by eval/run_dab_eval.py)
DAB_DATASET=yelp
DAB_TRIALS_PER_QUERY=1
# Optional single-query smoke for eval/run_query.py
# DAB_QUERY_INDEX=0
